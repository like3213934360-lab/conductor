# 打包到 VSIX 时排除的文件
# esbuild 已将所有源码打包到 dist/, 不需要源文件

# 源码 (已打包进 dist/)
src/**
packages/**
*.ts
*.tsx
tsconfig*.json

# 开发文件
.omc/**
.git/**
.github/**
.agents/workflows/**
.agents/skills/*/scripts/**
.agents/skills/*/examples/**
.agents/skills/*/resources/**
# .agents/skills/*/SKILL.md 会被保留 — 这是 autoInstallSkill() 的数据源
.claude/**
.gemini/**
node_modules/**
**/*.map
**/*.d.ts
**/*.tsbuildinfo

# 构建工具配置
vitest.config.*
turbo.json
.eslintrc*
.prettierrc*
code-linter.json5

# 分发/临时
*.vsix
*.tgz

# 文档 (不打包进 VSIX)
CHANGELOG.md
CONTRIBUTING.md
