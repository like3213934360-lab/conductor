# 打包到 VSIX 时排除的文件
# esbuild 已将所有源码打包到 dist/extension.js, 不需要源文件

# 源码 (已打包进 dist/)
src/**
packages/**
*.ts
tsconfig*.json

# 开发文件
.omc/**
.git/**
.github/**
.agents/**
.claude/**
.gemini/**
node_modules/**
**/*.map
**/*.d.ts

# 构建产物/临时文件
*.vsix
*.tgz
.eslintrc*
.prettierrc*
code-linter.json5
vitest.config.*

# 文档 (不打包进 VSIX)
CHANGELOG.md
CONTRIBUTING.md
