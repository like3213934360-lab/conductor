{
  "name": "conductor-hub",
  "displayName": "Conductor Hub",
  "description": "多 Agent 治理引擎 — 多模型编排 + AGC 工作流 + MCP 自动注册",
  "version": "0.3.0",
  "publisher": "like3213934360-lab",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/like3213934360-lab/conductor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "arkts",
    "harmonyos",
    "conductor",
    "multi-agent",
    "agc",
    "ai-orchestration",
    "mcp"
  ],
  "activationEvents": [
    "onLanguage:arkts",
    "workspaceContains:**/*.ets",
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "arkts",
        "aliases": ["ArkTS", "arkts", "ets"],
        "extensions": [".ets"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arkts",
        "scopeName": "source.ets",
        "path": "./syntaxes/ets.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "ArkTS DevEco (Darcula)",
        "uiTheme": "vs-dark",
        "path": "./themes/deveco-darcula-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "conductor-hub.openPanel",
        "title": "Conductor Hub: 打开控制面板",
        "icon": "$(dashboard)"
      },
      {
        "command": "conductor-hub.runAgc",
        "title": "Conductor Hub: 运行 AGC",
        "icon": "$(run-all)"
      }
    ],
    "configuration": {
      "title": "Conductor Hub",
      "properties": {
        "arkts.deveco.path": {
          "type": "string",
          "default": "",
          "description": "自定义 DevEco Studio 安装路径（留空则自动检测）"
        },
        "arkts.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "LSP 通信日志级别（调试用）"
        },
        "conductor-hub._dashboardTip": {
          "type": "string",
          "default": "👉 点击右下角 'Conductor Hub' 打开 Dashboard 👈",
          "description": "💡 模型配置不在本页！Conductor Hub 使用可视化 Dashboard。请点击右下角状态栏的 'Conductor Hub' 按钮，或使用 Cmd+Shift+P → 'Conductor Hub: 打开控制面板'。",
          "order": 1
        },
        "conductor-hub.defaultModel": {
          "type": "string",
          "default": "deepseek",
          "enum": ["deepseek", "glm", "qwen", "minimax", "kimi", "gpt", "gemini", "mistral"],
          "description": "默认路由大模型（未触发垂直分支时的兜底模型）",
          "order": 2
        },
        "conductor-hub.retentionDays": {
          "type": "number",
          "default": 30,
          "description": "自动清理历史记录的天数",
          "order": 3
        }
      }
    },
    "semanticTokenTypes": [
      {
        "id": "decorator",
        "superType": "type",
        "description": "ArkTS decorator name (e.g. @Component, @State)"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "arkts",
        "scopes": {
          "decorator": [
            "entity.name.function.decorator",
            "support.type",
            "entity.name.type"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[arkts]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "namespace:arkts": "#A9B7C6",
          "type:arkts": "#A9B7C6",
          "class:arkts": "#A9B7C6",
          "enum:arkts": "#A9B7C6",
          "interface:arkts": "#A9B7C6",
          "struct:arkts": "#A9B7C6",
          "typeParameter:arkts": "#A9B7C6",
          "parameter:arkts": "#A9B7C6",
          "variable:arkts": "#A9B7C6",
          "property:arkts": "#9876AA",
          "enumMember:arkts": "#9876AA",
          "function:arkts": "#FFC66D",
          "method:arkts": "#FFC66D",
          "keyword:arkts": "#CC7832",
          "string:arkts": "#6A8759",
          "number:arkts": "#6897BB",
          "comment:arkts": "#808080",
          "operator:arkts": "#A9B7C6",
          "decorator:arkts": "#BBB529",
          "variable.readonly:arkts": "#A9B7C6",
          "property.static:arkts": {
            "foreground": "#9876AA",
            "fontStyle": "italic"
          },
          "method.static:arkts": {
            "foreground": "#FFC66D",
            "fontStyle": "italic"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build --prefix packages/conductor-hub-webview && mkdir -p dist && esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify && esbuild ./packages/conductor-mcp-server/src/main.ts --bundle --outfile=dist/conductor-mcp-server.js --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "npx vsce package --no-dependencies -o conductor-hub.vsix",
    "install-ext": "npx vsce package --no-dependencies -o conductor-hub.vsix && code --install-extension conductor-hub.vsix && rm conductor-hub.vsix && cp dist/webview.js dist/extension.js dist/conductor-mcp-server.js ~/.antigravity/extensions/like3213934360-lab.conductor-hub-0.3.0/dist/ 2>/dev/null; echo '✅ Installed to both VS Code & Antigravity'",
    "build:conductor": "tsc -b packages/conductor-shared packages/conductor-core packages/conductor-persistence",
    "build:conductor-hub": "tsc -b packages/conductor-hub-shared packages/conductor-hub-core packages/conductor-hub-persistence packages/conductor-hub-adapter",
    "build:conductor-mcp": "tsc -b packages/conductor-mcp-server",
    "build:all": "npm run build:conductor && npm run build:conductor-hub && npm run build:conductor-mcp",
    "typecheck:conductor": "tsc -b packages/conductor-shared packages/conductor-core packages/conductor-persistence --pretty",
    "typecheck:conductor-hub": "tsc -b packages/conductor-hub-shared packages/conductor-hub-core packages/conductor-hub-persistence packages/conductor-hub-adapter --pretty",
    "typecheck:conductor-mcp": "tsc -b packages/conductor-mcp-server --pretty",
    "typecheck:all": "npm run typecheck:conductor && npm run typecheck:conductor-hub && npm run typecheck:conductor-mcp",
    "turbo:build": "turbo run build",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:clean": "turbo run clean && rm -rf dist",
    "clean": "rm -rf packages/*/dist dist"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
