{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "composite": true
  },
  "references": [
    { "path": "../antigravity-model-shared" },
    { "path": "../antigravity-core" },
    { "path": "../antigravity-shared" }
  ],
  "include": ["src/**/*.ts"]
}
