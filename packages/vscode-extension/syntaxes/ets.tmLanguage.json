{
    "name": "ArkTS",
    "scopeName": "source.ets",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#decorators"
        },
        {
            "include": "#struct-declaration"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#storage"
        },
        {
            "include": "#types"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#this-keyword"
        },
        {
            "include": "#ui-components"
        },
        {
            "include": "#method-calls"
        },
        {
            "include": "#property-access"
        },
        {
            "include": "#functions"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "comment": "JSDoc / block doc comments — DevEco uses green #629755",
                    "name": "comment.block.documentation.ets",
                    "begin": "/\\*\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "name": "keyword.other.documentation.ets",
                            "match": "@\\w+"
                        }
                    ]
                },
                {
                    "name": "comment.block.ets",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.double-slash.ets",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.single.ets",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.ets",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.ets",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.ets",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.template.ets",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "name": "constant.character.escape.ets",
                            "match": "\\\\."
                        },
                        {
                            "name": "meta.template.expression.ets",
                            "begin": "\\$\\{",
                            "end": "\\}",
                            "beginCaptures": {
                                "0": {
                                    "name": "punctuation.definition.template-expression.begin.ets"
                                }
                            },
                            "endCaptures": {
                                "0": {
                                    "name": "punctuation.definition.template-expression.end.ets"
                                }
                            },
                            "patterns": [
                                {
                                    "include": "source.ets"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "decorators": {
            "patterns": [
                {
                    "comment": "ArkTS decorators: @Component, @State, @Param, @Require, etc.",
                    "name": "meta.decorator.ets",
                    "match": "(@)(\\w+)",
                    "captures": {
                        "1": {
                            "name": "punctuation.decorator.ets"
                        },
                        "2": {
                            "name": "entity.name.tag.decorator.ets"
                        }
                    }
                }
            ]
        },
        "struct-declaration": {
            "patterns": [
                {
                    "comment": "ArkTS struct keyword (used for UI components)",
                    "match": "\\b(struct)\\s+(\\w+)",
                    "captures": {
                        "1": {
                            "name": "storage.type.struct.ets"
                        },
                        "2": {
                            "name": "entity.name.type.class.ets"
                        }
                    }
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.ets",
                    "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|throw|try|catch|finally|in|of|yield|await|async)\\b"
                },
                {
                    "name": "keyword.operator.ets",
                    "match": "\\b(new|delete|typeof|instanceof|void|as|is|keyof|infer)\\b"
                },
                {
                    "name": "keyword.control.import.ets",
                    "match": "\\b(import|export|from|default)\\b"
                }
            ]
        },
        "storage": {
            "patterns": [
                {
                    "name": "storage.type.ets",
                    "match": "\\b(let|const|var|function|class|interface|enum|type|namespace|module|extends|implements|abstract|static|readonly|private|protected|public|override|declare)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.ets",
                    "match": "\\b(string|number|boolean|void|null|undefined|never|any|unknown|object|symbol|bigint)\\b"
                },
                {
                    "comment": "ArkTS-specific types: Resource, Length, etc.",
                    "name": "support.type.arkts.ets",
                    "match": "\\b(Resource|Length|Dimension|ResourceStr|ResourceColor|Padding|Margin|EdgeWidths|BorderRadiuses|Position|Area|EventTarget|TouchObject|KeyEvent|PixelMap)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.ets",
                    "match": "\\b(true|false|null|undefined|NaN|Infinity)\\b"
                },
                {
                    "name": "constant.numeric.ets",
                    "match": "\\b(0[xX][0-9a-fA-F]+|0[oO][0-7]+|0[bB][01]+|\\d+(\\.\\d+)?([eE][+-]?\\d+)?)\\b"
                }
            ]
        },
        "this-keyword": {
            "patterns": [
                {
                    "comment": "this keyword — DevEco colors as keyword #CC7832",
                    "name": "variable.language.this.ets",
                    "match": "\\bthis\\b"
                }
            ]
        },
        "ui-components": {
            "patterns": [
                {
                    "comment": "ArkUI built-in components (PascalCase identifiers followed by parens)",
                    "match": "\\b(Column|Row|Stack|Flex|List|ListItem|ListItemGroup|Grid|GridItem|Scroll|Swiper|Tabs|TabContent|Text|Span|Image|Button|TextInput|TextArea|Toggle|Checkbox|Radio|Select|Slider|Rating|Progress|LoadingProgress|Divider|Blank|Search|Navigation|NavRouter|NavDestination|Navigator|Panel|Refresh|WaterFlow|FlowItem|RelativeContainer|SideBarContainer|Counter|Marquee|Gauge|DataPanel|Badge|ScrollBar|Menu|MenuItem|MenuItemGroup|AlertDialog|ActionSheet|CustomDialog|DatePicker|TimePicker|TextPicker|CalendarPicker|Video|Web|XComponent|Canvas|Circle|Ellipse|Line|Path|Polygon|Polyline|Rect|Shape|SymbolGlyph|RichText|Hyperlink|ImageAnimator|ForEach|LazyForEach)(?=\\s*\\()",
                    "name": "entity.name.function.component.ets"
                }
            ]
        },
        "method-calls": {
            "patterns": [
                {
                    "comment": "Method calls on objects: .foo() — DevEco colors method as yellow #FFC66D",
                    "match": "(?<=\\.)([a-zA-Z_$][\\w$]*)(?=\\s*\\()",
                    "name": "entity.name.function.method.ets"
                }
            ]
        },
        "property-access": {
            "patterns": [
                {
                    "comment": "Property access: .foo (not followed by parens) — DevEco colors as purple #9876AA",
                    "match": "(?<=\\.)([a-zA-Z_$][\\w$]*)(?!\\s*\\()",
                    "name": "variable.other.property.ets"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "comment": "Function calls (not after dot): foo() — DevEco colors as yellow #FFC66D",
                    "match": "\\b([a-zA-Z_$][\\w$]*)(?=\\s*\\()",
                    "name": "entity.name.function.ets"
                }
            ]
        }
    }
}