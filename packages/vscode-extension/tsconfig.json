{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*.ts",
    "../ace-bridge/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
