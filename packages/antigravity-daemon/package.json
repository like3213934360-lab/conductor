{
  "name": "@anthropic/antigravity-daemon",
  "version": "0.1.0",
  "private": true,
  "description": "Antigravity 专用 daemon-owned workflow runtime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "smoke": "node smoke.mjs",
    "typecheck": "npm run clean && tsc -b --pretty",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic/antigravity-core": "*",
    "@anthropic/antigravity-model-core": "*",
    "@anthropic/antigravity-persistence": "*",
    "@anthropic/antigravity-shared": "*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
