{
  "name": "@anthropic/antigravity-mcp-server",
  "version": "0.1.0",
  "description": "Antigravity Workflow Runtime — MCP Server 入口、工具注册、stdio/http transport",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "antigravity-mcp": "dist/main.js"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "node dist/main.js",
    "smoke": "node smoke.mjs",
    "typecheck": "npm run clean && tsc -b --pretty",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic/antigravity-model-core": "*",
    "@anthropic/antigravity-taskd": "*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
