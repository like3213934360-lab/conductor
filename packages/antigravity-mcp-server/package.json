{
  "name": "@anthropic/antigravity-mcp-server",
  "version": "0.1.0",
  "description": "Antigravity Workflow Runtime \u2014 MCP Server \u5165\u53e3\u3001\u5de5\u5177\u6ce8\u518c\u3001stdio/http transport",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "antigravity-mcp": "dist/main.js"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "node dist/main.js",
    "smoke": "node smoke.mjs",
    "typecheck": "npm run clean && tsc -b --pretty",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic/antigravity-daemon": "*",
    "@anthropic/antigravity-model-core": "*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
